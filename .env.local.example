VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF3d3dpanlsamdobWxlcnlsYnBpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMwNzA4MzYsImV4cCI6MjA5ODY0NjgzNn0.RvXy2yDiMNLEw9pqXooplQD21EpnvRfoIT239jGx6s4
VITE_APP_ENV=production

# Vocatio platform admin (after migration 012 + deploying admin-auth function):
# 1. Sign up / log in with your @vocatio.io account in the app
# 2. In Supabase SQL: INSERT INTO platform_admins (user_id, email)
#    SELECT id, email FROM auth.users WHERE email = 'you@vocatio.io';
# 3. Open https://yoursite/vocatio-admin and complete two-factor setup

# ─── Staging (mock / trial testing) ────────────────────────────────────────────
# Use a SEPARATE Supabase project so staging never touches production data.
# Deploy preview/staging with:
#   VITE_APP_ENV=staging
#   VITE_SUPABASE_URL=https://your-staging-project.supabase.co
#   VITE_SUPABASE_ANON_KEY=your-staging-anon-key
#   VITE_ADMIN_DEMO_DEFAULT=true
#
# Sign up with a different email on staging. Your production account keeps your real workspace.

# ─── Local without cloud ─────────────────────────────────────────────────────
# Leave Supabase vars empty to run fully in the browser (localStorage only).
# Data stays on this machine until you connect Supabase and sign up.

# ─── Stripe (billing) ────────────────────────────────────────────────────────
# Create products/prices in Stripe Dashboard, then paste Price IDs here and in Vercel.
VITE_STRIPE_PRICE_SOLO_MONTHLY=
VITE_STRIPE_PRICE_SOLO_ANNUAL=
VITE_STRIPE_PRICE_BUSINESS_MONTHLY=
VITE_STRIPE_PRICE_BUSINESS_ANNUAL=
VITE_STRIPE_PRICE_GROUP_MONTHLY=
VITE_STRIPE_PRICE_GROUP_ANNUAL=

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# OPENAI_API_KEY=sk-...
# ADMIN_SESSION_HOURS=8
